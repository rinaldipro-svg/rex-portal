# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rex_portal

# API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# JWT
JWT_SECRET=votre-secret-jwt-super-securise-minimum-32-caracteres

# AWS S3 (ou Cloudflare R2)
